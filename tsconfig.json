{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "composite": true,
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./"
  },
  "include": [
    "*.ts",
    "*.tsx",
    "*.mts",
    "*.cts",
    "src/",
    "test/",
    "scripts/",
    "site/src/utils/markdown.ts",
    "./package.json",
    "src/**/*.json",
    "test/**/*.json",
    "src/types/globals.d.ts",
    "src/types/optional-deps.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/app/**/*",
    "test/code-scan-action/**/*",
    "test/fixtures/rubric-json-template/rubric.json"
  ]
}
