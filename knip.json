{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{js,cjs,mjs,ts}",
        "plugins/**/scripts/**/*.{js,cjs,mjs,ts}",
        "src/redteam/plugins/policy/evals/**/*.{js,cjs,mjs,ts}",
        "src/logger.browser.ts",
        "src/util/createHash.browser.ts",
        "src/util/agent/targetLinkFs.ts",
        "test/__fixtures__/**/*.{js,cjs,mjs,ts}",
        "test/fixtures/**/*.{js,cjs,mjs,ts}",
        "test/smoke/fixtures/**/*.{js,cjs,mjs,ts}",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.{js,ts,tsx}",
        "scripts/**/*.{js,cjs,mjs,ts}",
        "plugins/**/*.{js,cjs,mjs,ts}",
        "test/**/*.{js,ts,tsx,cjs,mjs}",
        "!src/app/**/*"
      ],
      "ignoreFiles": [
        "src/providers/audio/**/*.{js,ts,tsx}",
        "src/redteam/audio/**/*.{js,ts,tsx}",
        "src/redteam/strategies/multilingual.ts"
      ],
      "ignoreDependencies": [
        "@actions/*",
        "@octokit/rest",
        "@types/pdf-parse",
        "block-no-verify",
        "gcp-metadata",
        "langium"
      ],
      "paths": {
        "@promptfoo/*": ["./src/*"]
      }
    },
    "src/app": {
      "entry": ["index.html"],
      "project": ["src/**/*.{js,ts,tsx}"],
      "ignoreFiles": ["src/polyfills/scroll-timeline.d.ts"],
      "ignoreDependencies": ["@kurkle/color", "lightningcss", "tailwindcss"],
      "paths": {
        "@app/*": ["./src/*"],
        "@promptfoo/*": ["../../*"]
      }
    },
    "site": {
      "entry": [
        "*.config.{js,ts}",
        "src/**/*.{js,ts,tsx}",
        "blog/**/*.{js,ts,tsx}",
        "docs/**/*.{md,mdx}"
      ],
      "project": ["**/*.{js,ts,tsx}"],
      "ignoreFiles": ["docs/_shared/**/*.{js,ts,tsx}", "static/js/scripts.js"],
      "ignoreDependencies": [
        "@docusaurus/types",
        "@docusaurus/theme-common",
        "@theme/*",
        "@mui/*",
        "@generated/*",
        "@docusaurus/plugin-content-blog",
        "@swc/core",
        "@swc/jest",
        "dompurify",
        "langium",
        "webpack"
      ]
    },
    "code-scan-action": {
      "project": ["src/**/*.{js,ts,tsx}"]
    }
  },
  "ignoreBinaries": [
    "act",
    "dist/src/entrypoint.js",
    "ffmpeg",
    "gh",
    "go",
    "modelaudit",
    "python3",
    "ruby",
    "security"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/contracts/api/user.ts": ["duplicates"],
    "src/redteam/plugins/multiInputFormat.ts": ["exports"],
    "src/redteam/providers/custom/index.ts": ["duplicates"],
    "src/redteam/providers/hydra/index.ts": ["duplicates"],
    "src/types/api/**": ["duplicates", "types"],
    "src/types/codeScan.ts": ["exports", "types"],
    "src/types/modelAudit.ts": ["types"],
    "src/types/targetLink.ts": ["types"],
    "src/util/sanitizer.ts": ["duplicates"]
  }
}
