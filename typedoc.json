{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "plugin": ["typedoc-plugin-markdown"],
  "out": "site/docs/api/node/reference",
  "readme": "none",
  "excludeInternal": true,
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  }
}
